{
  "name": "@minix/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "ci": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run --filter \"@minix/*\" dev",
    "dev:cli": "vp run @minix/cli#dev",
    "dev:compiler": "vp run @minix/compiler#dev",
    "dev:components": "vp run @minix/components#dev",
    "dev:launcher": "vp run @minix/launcher#dev",
    "dev:toolbar": "vp run @minix/toolbar#dev",
    "dev:minix": "vp run @minix/minix#dev",
    "dev:plugin": "vp run @minix/vite-plus#dev",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-vue": "catalog:vue",
    "vite": "catalog:vite",
    "vite-plus": "catalog:vite"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.13.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
