page {
  background: #f6f7f9;
}
.container {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  border: none;
  border-radius: 999rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  cursor: pointer;
}
.btn.plain {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
}
.muted {
  color: #999;
  font-size: 24rpx;
}
