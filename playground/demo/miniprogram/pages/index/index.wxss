.counter {
  text-align: center;
}
.count {
  display: block;
  font-size: 96rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}
.row {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}
.section {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 20rpx;
}
.article {
  cursor: pointer;
}
.article:active {
  opacity: 0.7;
}
.article-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
