<view class="container">
  <view class="card counter">
    <text class="count">{{count}}</text>
    <view class="row">
      <button class="btn plain" bind:tap="dec">− 1</button>
      <button class="btn" bind:tap="inc">＋ 1</button>
    </view>
  </view>

  <view>
    <text>适配展示</text>
    <button loading="{{true}}" ss="ss">默认按钮</button>
    <button loading="{{true}}" size="mini">小</button>

    <!-- <view> -->
    <image src="https://res.wx.qq.com/wxdoc/dist/assets/img/0.4cb08bb4.jpg"></image>
    <!-- </view> -->
  </view>

  <view class="section">文章列啊阿萨萨啊啊啊啊啊啊表 · {{articles.length}} 篇</view>

  <block wx:for="{{articles}}" wx:key="id">
    <view class="card article" data-id="{{item.id}}" bind:tap="openDetail">
      <text class="article-title">{{index + 1}}. {{item.title}}</text>
      <text class="muted">{{item.desc}}</text>
    </view>
  </block>

  <view wx:if="{{articles.length === 0}}" class="muted">暂无文章</view>
</view>
