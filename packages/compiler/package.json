  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippedround/minix.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
