{
  "name": "@minix/compiler",
  "version": "0.0.0",
  "description": "WXML to Vue Vapor render function compiler for minix.",
  "homepage": "https://github.com/flippedround/minix.git#readme",
  "bugs": {
    "url": "https://github.com/flippedround/minix/issues"
