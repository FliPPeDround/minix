{
  "name": "@minix/cli",
  "version": "0.0.0",
  "description": "Zero-config CLI to run WeChat mini-program projects in the browser",
  "homepage": "https://github.com/flippedround/minix.git#readme",
  "bugs": {
    "url": "https://github.com/flippedround/minix/issues"
  },
  "license": "MIT",
