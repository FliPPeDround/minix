{
  "name": "@minix/toolbar",
  "version": "0.0.0",
  "private": true,
  "description": "Native webview toolbar for minix — wraps the Vite dev server in a desktop window with a modern toolbar (device switching, DevTools toggle, always-on-top).",
  "homepage": "https://github.com/flippedround/minix.git#readme",
  "bugs": {
    "url": "https://github.com/flippedround/minix/issues"
  },
  "license": "MIT",
  "author": "FlippedRound <flippedround@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippedround/minix.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.html"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp build --watch",
    "build": "vp build",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "@vitejs/plugin-vue": "catalog:vue",
    "typescript": "catalog:types",
    "vite-plugin-singlefile": "catalog:",
    "vite-plus": "catalog:vite",
    "vue": "catalog:vue"
  }
}
