{
  "name": "@minix/launcher",
  "version": "0.0.0",
  "description": "Native webview launcher for minix — wraps the Vite dev server in a desktop window with a modern toolbar (device switching, DevTools toggle, always-on-top).",
  "homepage": "https://github.com/flippedround/minix.git#readme",
  "bugs": {
    "url": "https://github.com/flippedround/minix/issues"
  },
  "license": "MIT",
  "author": "FlippedRound <flippedround@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippedround/minix.git"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "typescript": "catalog:types",
    "vite-plus": "catalog:vite"
  },
  "peerDependencies": {
    "@webviewjs/webview": "catalog:webview"
  },
  "peerDependenciesMeta": {
    "@webviewjs/webview": {
      "optional": true
    }
  }
}
