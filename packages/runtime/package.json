{
  "name": "@minix/runtime",
  "version": "0.0.0",
  "description": "Mini-program runtime for browsers, powered by Vue Vapor Mode",
  "homepage": "https://github.com/flippedround/minix.git#readme",
  "bugs": {
    "url": "https://github.com/flippedround/minix/issues"
