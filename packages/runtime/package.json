    "@vue/shared": "catalog:vue",
    "jsdom": "catalog:test",
    "miniprogram-api-typings": "catalog:types",
    "typescript": "catalog:types",
    "vite": "catalog:vite",
    "vite-plus": "catalog:vite"
  },
  "inlinedDependencies": {
    "@vue/reactivity": "3.6.0-rc.1",
    "@vue/runtime-core": "3.6.0-rc.1",
    "@vue/runtime-dom": "3.6.0-rc.1",
    "@vue/runtime-vapor": "3.6.0-rc.1",
    "@vue/shared": "3.6.0-rc.1",
    "csstype": "3.2.3"
  }
